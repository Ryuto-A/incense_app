<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for?(:title) ? "#{yield(:title)} | " : "" %>IncenseApp</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- OGP (static) -->
    <meta property="og:type" content="website">
    <meta property="og:locale" content="ja_JP">
    <meta property="og:site_name" content="IncenseApp">
    <meta property="og:title" content="IncenseApp | お香レビュー投稿アプリ">
    <meta property="og:description" content="お香のレビューや情報を共有できるアプリです。香りカテゴリ・煙の強さ・タグ検索にも対応。">
    <meta property="og:image" content="<%= "#{request.base_url}/ogp.png" %>">
    <meta property="og:url" content="<%= request.base_url %>">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="IncenseApp | お香レビュー投稿アプリ">
    <meta name="twitter:description" content="お香のレビューや情報を共有できるアプリです。香りカテゴリ・煙の強さ・タグ検索にも対応。">
    <meta name="twitter:image" content="<%= "#{request.base_url}/ogp.png" %>">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if flash[:notice] %>
      <p class="alert alert-info"><%= flash[:notice] %></p>
    <% end %>
    <% if flash[:alert] %>
      <p class="alert alert-danger"><%= flash[:alert] %></p>
    <% end %>

    <%= render "shared/navbar" %>

    <div class="container mt-4">
      <%= yield %>
    </div>

    <footer class="border-top py-3 mt-5 small">
      <div class="container d-flex flex-wrap gap-3 justify-content-between">
        <div class="text-muted">&copy; <%= Time.current.year %> IncenseApp</div>
        <nav class="ms-auto">
          <ul class="list-inline mb-0">
            <li class="list-inline-item">
              <%= link_to t('views.pages.nav.terms', locale: :ja), terms_path, class: "link-secondary" %>
            </li>
            <li class="list-inline-item">|</li>
            <li class="list-inline-item">
              <%= link_to t('views.pages.nav.privacy', locale: :ja), privacy_path, class: "link-secondary" %>
            </li>
            <li class="list-inline-item">|</li>
            <li class="list-inline-item">
              <%= link_to "お問い合わせ", contact_path, class: "link-secondary" %>
            </li>
          </ul>
        </nav>
      </div>
    </footer>
  </body>
</html>
